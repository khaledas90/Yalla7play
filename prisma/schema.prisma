generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  WORKER
  SUPER_ADMIN
  ADMIN
}

enum AdType {
  IMAGE
  SCRIPT
}

enum AdPosition {
  HEADER
  SIDEBAR
  BETWEEN_ITEMS
  FOOTER
  POPUP
}

enum StoreType {
  PLAY_STORE
  APP_STORE
  OTHER
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REVISION
}

model User {
  id                String   @id @default(uuid())
  name              String?
  email             String   @unique
  password          String
  phone             String?
  avatar            String?
  role              Role     @default(USER)
  isActive          Boolean  @default(true)
  defaultProfitRate Float?
  workerRevenueRate Float?  @default(0)
  games             Game[]  @relation("WorkerGames")
  apps              App[]   @relation("WorkerApps")
  comments          Comment[]
  ratings           Rating[]
  workerStats       WorkerDailyStat[]
  workerEarnings    WorkerEarning[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Category {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  icon      String?
  createdAt DateTime @default(now())

  games Game[]
  apps  App[]
}

model Game {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  description   String   @db.Text
  thumbnail     String
  gallery       Json?
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  version         String?
  updateInfo      String?   @db.Text
  operatingSystem String?
  developer       String?
  size            String?
  storeType       StoreType @default(OTHER)
  playStoreUrl    String?
  appStoreUrl     String?
  downloadUrl     Json?
  securityCheck   String?
  workerId        String?
  worker          User?     @relation("WorkerGames", fields: [workerId], references: [id])
  comments        Comment[]
  ratings         Rating[]
  views         Int      @default(0)
  downloads     Int      @default(0)
  rating        Float    @default(0)
  ratingCount   Int      @default(0)
  isFeatured    Boolean  @default(false)
  isTrending    Boolean  @default(false)
  seoTitle      String?
  seoDescription String?
  published     Boolean  @default(true)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([views])
  @@index([downloads])
}

model App {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  description   String   @db.Text
  thumbnail     String
  gallery       Json?
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  version         String?
  updateInfo      String?   @db.Text
  operatingSystem String?
  developer       String?
  size            String?
  storeType       StoreType @default(OTHER)
  playStoreUrl    String?
  appStoreUrl     String?
  downloadUrl     Json?
  securityCheck   String?
  workerId        String?
  worker          User?     @relation("WorkerApps", fields: [workerId], references: [id])
  comments        Comment[]
  ratings         Rating[]
  views         Int      @default(0)
  downloads     Int      @default(0)
  rating        Float    @default(0)
  ratingCount   Int      @default(0)
  isFeatured    Boolean  @default(false)
  isTrending    Boolean  @default(false)
  seoTitle      String?
  seoDescription String?
  published     Boolean  @default(true)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([views])
  @@index([downloads])
}

model Blog {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  excerpt        String?  @db.Text
  content        String   @db.LongText
  image          String?
  author         String?
  isPublished    Boolean  @default(false)
  publishedAt    DateTime?
  views          Int      @default(0)
  category       String?
  tags           Json?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([views])
  @@index([createdAt])
}


model Ad {
  id        String     @id @default(uuid())
  title     String
  type      AdType
  position  AdPosition
  imageUrl  String?
  link      String?
  script    String?    @db.LongText
  isActive  Boolean    @default(true)
  frequency Int?
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime   @default(now())
}

model Setting {
  id             String   @id @default(uuid())
  siteName       String
  logo           String?
  primaryColor   String?
  secondaryColor String?
  seoTitle       String?
  seoDescription String?
  siteKeywords   String?
  adsEnabled     Boolean  @default(true)
  currency       String   @default("JOD")
  updatedAt      DateTime @updatedAt
}

model ViewLog {
  id        String   @id @default(uuid())
  entityId  String
  type      String
  ip        String?
  createdAt DateTime @default(now())
}

model Comment {
  id        String    @id @default(uuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id])
  gameId    String?
  game      Game?     @relation(fields: [gameId], references: [id])
  appId     String?
  app       App?      @relation(fields: [appId], references: [id])
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  content   String    @db.Text
  likes     Int       @default(0)
  dislikes  Int       @default(0)
  createdAt DateTime  @default(now())
}

model Rating {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  gameId    String?
  game      Game?    @relation(fields: [gameId], references: [id])
  appId     String?
  app       App?     @relation(fields: [appId], references: [id])
  value     Int
  createdAt DateTime @default(now())
}

model WorkerDailyStat {
  id          String   @id @default(uuid())
  workerId    String
  worker      User     @relation(fields: [workerId], references: [id])
  date        DateTime
  traffic     Int      @default(0)
  adViews     Int      @default(0)
  earnings    Float    @default(0)
  revenueRate Float    @default(0)
  createdAt   DateTime @default(now())

  @@index([workerId, date])
}

model WorkerEarning {
  id          String   @id @default(uuid())
  workerId    String
  worker      User     @relation(fields: [workerId], references: [id])
  sourceType  String
  sourceId    String?
  grossAmount Float
  workerRate  Float
  workerShare Float
  createdAt   DateTime @default(now())

  @@index([workerId, createdAt])
}
